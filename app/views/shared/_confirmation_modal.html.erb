<!-- Modal de Confirmação Abstrato -->
<div data-controller="confirmation-modal">
  <!-- Overlay -->
  <div data-confirmation-modal-target="modal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50">
    <!-- Modal Content -->
    <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white">
      <!-- Header -->
      <div class="flex items-center justify-between mb-4">
        <h3 data-confirmation-modal-target="title" class="text-lg font-medium text-gray-900">
          Confirmação
        </h3>
        <button data-action="click->confirmation-modal#hide" 
                class="text-gray-400 hover:text-gray-600 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      
      <!-- Icon Dinâmico (pode ser customizado via CSS) -->
      <div class="flex items-center justify-center w-12 h-12 mx-auto mb-4 bg-blue-100 rounded-full modal-icon">
        <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z">
          </path>
        </svg>
      </div>
      
      <!-- Message -->
      <div class="text-center mb-6">
        <div data-confirmation-modal-target="message" class="text-gray-700">
          <!-- Mensagem será inserida aqui -->
        </div>
      </div>
      
      <!-- Form (invisível) -->
      <form data-confirmation-modal-target="form" method="post" class="hidden">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <%= hidden_field_tag :_method, :delete %>
      </form>
      
      <!-- Buttons -->
      <div class="flex justify-end space-x-3">
        <button data-confirmation-modal-target="cancelButton"
                data-action="click->confirmation-modal#hide" 
                class="px-4 py-2 bg-gray-300 text-gray-700 rounded-md hover:bg-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-500 transition-colors">
          Cancelar
        </button>
        <button data-confirmation-modal-target="confirmButton"
                data-action="click->confirmation-modal#confirm" 
                class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-colors">
          Confirmar
        </button>
      </div>
    </div>
  </div>
</div>

<!-- CSS para diferentes tipos de modal -->
<style>
  /* Delete Modal */
  [data-confirm-class*="red"] .modal-icon {
    @apply bg-red-100;
  }
  [data-confirm-class*="red"] .modal-icon svg {
    @apply text-red-600;
  }
  
  /* Success Modal */
  [data-confirm-class*="green"] .modal-icon {
    @apply bg-green-100;
  }
  [data-confirm-class*="green"] .modal-icon svg {
    @apply text-green-600;
  }
  
  /* Warning Modal */
  [data-confirm-class*="yellow"] .modal-icon {
    @apply bg-yellow-100;
  }
  [data-confirm-class*="yellow"] .modal-icon svg {
    @apply text-yellow-600;
  }
</style>