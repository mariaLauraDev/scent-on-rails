<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold">Todos os Materiais</h1>
  </div>

  <% if @materials.any? %>
    <div class="grid gap-4">
      <% @materials.each do |material| %>
        <div class="bg-white p-6 rounded-lg shadow-md border">
          <div class="flex justify-between items-start">
            <div class="flex-1">
              <h3 class="text-xl font-semibold mb-2"><%= material.name %></h3>
              <p class="text-gray-600 mb-3"><%= material.description %></p>
              
              <div class="flex items-center gap-4 mb-3">
                <span class="inline-block px-3 py-1 text-sm bg-gray-100 rounded">
                  <%= material.material_type.humanize %>
                </span>
                <span class="text-sm text-gray-500">
                  Usado em <%= pluralize(material.batches.count, 'lote', 'lotes') %>
                </span>
              </div>

              <% if material.batches.any? %>
                <div>
                  <h4 class="text-sm font-medium text-gray-700 mb-2">Lotes que usam este material:</h4>
                  <div class="flex flex-wrap gap-2">
                    <% material.batches.each do |batch| %>
                      <%= link_to batch.name, batch, 
                          class: "inline-block px-2 py-1 text-xs bg-blue-100 text-blue-800 rounded hover:bg-blue-200" %>
                    <% end %>
                  </div>
                </div>
              <% else %>
                <p class="text-sm text-gray-500 italic">Material não está sendo usado em nenhum lote</p>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white p-8 rounded-lg shadow-md border text-center">
      <p class="text-gray-500 text-lg mb-4">Nenhum material foi criado ainda.</p>
      <p class="text-gray-400">Materiais são criados dentro dos lotes durante o processo de pesquisa.</p>
    </div>
  <% end %>
</div>