<div class="container mx-auto px-4 py-8">
  <div id="flash_messages"></div>
  
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold">Entrevistados</h1>
    <%= link_to "Novo Entrevistado", new_interviewee_path, class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
  </div>

  <div class="grid gap-4" id="batches">
    <%= render @interviewees %>
    
    <% if @interviewees.empty? %>
      <div class="text-center py-12">
        <p class="text-gray-500 text-lg"> Nenhum entervistado criado ainda.</p>
        <%= link_to "Crie seu primeiro entervistado", new_interviewee_path, class: "text-blue-600 hover:underline" %>
      </div>
    <% end %>
  </div>
</div>
