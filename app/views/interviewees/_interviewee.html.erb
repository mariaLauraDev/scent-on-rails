<div id="<%= dom_id(interviewee) %>" class="bg-white p-6 rounded-lg shadow-md border">
  <div class="flex justify-between items-start">
    <div>
      <h3 class="text-xl font-semibold mb-2"><%= interviewee.name %></h3>
      <div class="grid grid-cols-3 gap-4 text-sm text-gray-600 mb-2">
        <span><strong>Idade:</strong> <%= interviewee.age %> anos</span>
        <span><strong>Gênero:</strong> <%= interviewee.gender.humanize %></span>
        <span><strong>Setor:</strong> <%= interviewee.sector.humanize %></span>
      </div>
      <div class="text-sm text-gray-500">
        <span>Entrevistas: <%= interviewee.interviews.count %></span>
        <span class="ml-4">Cadastrado em: <%= interviewee.created_at.strftime("%d/%m/%Y") %></span>
        <% if interviewee.last_interview_date %>
          <span class="ml-4">Última entrevista em: <%= interviewee.last_interview_date&.strftime("%d/%m/%Y") %></span>
        <% end %>
      </div>
    </div>
    <div class="flex gap-2">
      <%= link_to "Ver", interviewee, class: "text-blue-600 hover:underline" %>
      <%= link_to "Editar", edit_interviewee_path(interviewee), class: "text-green-600 hover:underline" %>
      <%= link_to "Excluir", interviewee, 
          data: { 
            turbo_method: :delete, 
            turbo_confirm: "Tem certeza que deseja excluir #{interviewee.name}?" 
          }, 
          class: "text-red-600 hover:underline" %>
    </div>
  </div>
</div>