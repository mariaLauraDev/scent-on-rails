<div class="container mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-6">Editar Lote</h1>

  <%= form_with model: @batch, local: false, class: "space-y-6" do |form| %>
    <div class="bg-white p-6 rounded-lg shadow-md border">
      <h2 class="text-xl font-semibold mb-4">Informações do Lote</h2>
      <%= render "form", form: form %>
    </div>

    <div class="bg-white p-6 rounded-lg shadow-md border">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-xl font-semibold">Materiais</h2>
        <%= link_to "Criar Material", new_batch_batch_material_path(@batch), 
            class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded text-sm" %>
      </div>
      <% if @batch.materials.any? %>
        <div class="space-y-3">
          <% @batch.materials.each do |material| %>
            <div class="flex justify-between items-center p-3 border rounded">
              <div>
                <h4 class="font-medium"><%= material.name %></h4>
                <p class="text-sm text-gray-600"><%= material.description %></p>
                <span class="inline-block px-2 py-1 text-xs bg-gray-100 rounded">
                  <%= material.material_type.humanize %>
                </span>
              </div>
              <div class="flex gap-2">
                <%= link_to "Remover", batch_batch_material_path(@batch, material), 
                    data: { turbo_method: :delete, turbo_confirm: "Remover #{material.name} do lote?" },
                    class: "text-red-600 hover:underline text-sm" %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 italic">Nenhum material adicionado ainda.</p>
      <% end %>
    </div>

    <div class="bg-white p-6 rounded-lg shadow-md border">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-xl font-semibold">Perguntas</h2>
        <%= link_to "Criar Pergunta", new_batch_batch_question_path(@batch), 
            class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded text-sm" %>
      </div>
      <% if @batch.questions.any? %>
        <div class="space-y-3">
          <% @batch.questions.each do |question| %>
            <div class="flex justify-between items-start p-3 border rounded">
              <div class="flex-1">
                <h4 class="font-medium"><%= question.text %></h4>
                <% if question.description.present? %>
                  <p class="text-sm text-gray-600 mt-1"><%= question.description %></p>
                <% end %>
                <span class="inline-block px-2 py-1 text-xs bg-gray-100 rounded mt-2">
                  <%= question.question_type.humanize %>
                </span>
              </div>
              <div class="flex gap-2">
                <%= link_to "Remover", batch_batch_question_path(@batch, question), 
                    data: { turbo_method: :delete, turbo_confirm: "Remover pergunta do lote?" },
                    class: "text-red-600 hover:underline text-sm" %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 italic">Nenhuma pergunta adicionada ainda.</p>
      <% end %>
    </div>

    <div class="flex gap-4">
      <%= form.submit "Atualizar Lote", class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
      <%= link_to "Cancelar", @batch, class: "bg-gray-300 hover:bg-gray-400 text-gray-800 font-bold py-2 px-4 rounded" %>
    </div>
  <% end %>
</div>
