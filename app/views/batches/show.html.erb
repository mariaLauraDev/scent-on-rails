<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold"><%= @batch.name %></h1>
    <div class="flex gap-2">
      <%= link_to "Editar", edit_batch_path(@batch), class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
      <%= link_to "Voltar", batches_path, class: "bg-gray-500 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded" %>
    </div>
  </div>

  <div class="bg-white p-6 rounded-lg shadow-md border mb-6">
    <h2 class="text-xl font-semibold mb-4">Informações do Lote</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div>
        <span class="text-sm text-gray-500">Nome</span>
        <p class="font-medium"><%= @batch.name %></p>
      </div>
      <div>
        <span class="text-sm text-gray-500">Descrição</span>
        <p class="font-medium"><%= @batch.description %></p>
      </div>
      <div>
        <span class="text-sm text-gray-500">Data de Início</span>
        <p class="font-medium"><%= @batch.start_date&.strftime("%d/%m/%Y") %></p>
      </div>
      <div>
        <span class="text-sm text-gray-500">Status</span>
        <p class="font-medium"><%= @batch.status.humanize %></p>
      </div>
    </div>
  </div>

  <%= render "batch_material", materials: @materials, batch: @batch %>
  <%= render "batch_question", questions: @questions, batch: @batch %>
</div>