<div class="bg-white p-6 rounded-lg shadow-md border mb-6">
  <div class="flex justify-between items-center mb-4">
    <h2 class="text-xl font-semibold">Perguntas</h2>
    <%= link_to "Criar Pergunta", new_batch_question_path(batch), 
        class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded text-sm" %>
  </div>
  <% if questions.any? %>
    <div class="space-y-3">
      <% questions.each do |question| %>
        <div class="flex justify-between items-start p-3 border rounded">
          <div class="flex-1">
            <h4 class="font-medium"><%= question.text %></h4>
            <span class="inline-block px-2 py-1 text-xs bg-gray-100 rounded mt-2">
              <%= question.question_type.humanize %>
            </span>
          </div>
          <div class="flex gap-2">
            <%= link_to "Remover", batch_question_path(batch, question), 
                data: { turbo_method: :delete, turbo_confirm: "Remover pergunta do lote?" },
                class: "text-red-600 hover:underline text-sm" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-500 italic">Nenhuma pergunta adicionada ainda.</p>
  <% end %>
</div>